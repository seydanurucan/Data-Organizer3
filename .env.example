# ============================================================
#  CodeBuddy — Environment Variables
#  Bu dosyayı kopyalayıp ".env" olarak yeniden adlandırın
#  ve kendi değerlerinizi girin.
# ============================================================

# PostgreSQL bağlantı adresi
# Örnek (local):    postgresql://postgres:sifre@localhost:5432/codebuddy
# Örnek (Neon):     postgresql://user:pass@ep-xxx.neon.tech/codebuddy?sslmode=require
# Örnek (Supabase): postgresql://postgres:sifre@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/codebuddy

# JWT imzalama anahtarı — istediğiniz uzun rastgele bir metin yazın
SESSION_SECRET=buraya-cok-uzun-ve-rastgele-bir-sifre-yazin

# Sunucunun dinleyeceği port (genellikle değiştirmenize gerek yok)
PORT=5000

# ============================================================
#  YALNIZCA VERCEL DEPLOY'U İÇİN (Replit'te boş bırakın)
# ============================================================
# Vercel'e deploy ederken bu değeri, API sunucunuzun
# deploy edildiği URL'e ayarlayın.
# Örnek: https://codebuddy-api.railway.app
VITE_API_BASE_URL=
